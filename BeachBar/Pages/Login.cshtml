@page
@model BeachBar.Pages.LoginModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Belix — Accedi</title>
    <link rel="icon" href="/logo-belix.png" type="image/png" />
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #74b9ff 0%, #0984e3 100%);
            font-family: 'Segoe UI', system-ui, sans-serif;
        }
        .card {
            background: white;
            border-radius: 20px;
            padding: 48px 40px;
            width: 100%;
            max-width: 380px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.15);
            text-align: center;
        }
        .logo-wrapper {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px;
            margin-bottom: 28px;
        }
        .logo-wrapper img {
            height: 110px;
            width: auto;
        }
        .logo-wrapper h1 {
            font-size: 1.8rem;
            color: #2d3436;
            font-weight: 700;
        }
        .sub { color: #636e72; margin-bottom: 28px; font-size: 0.95rem; }
        label { display: block; text-align: left; font-size: 0.85rem; font-weight: 600; color: #2d3436; margin-bottom: 6px; }
        input[type=text], input[type=password] {
            width: 100%;
            padding: 12px 16px;
            border: 2px solid #dfe6e9;
            border-radius: 10px;
            font-size: 1rem;
            margin-bottom: 20px;
            transition: border-color 0.2s;
            text-align: left;
        }
        input[type=text]:focus, input[type=password]:focus {
            outline: none;
            border-color: #0984e3;
        }
        button[type=submit] {
            width: 100%;
            padding: 14px;
            background: #0984e3;
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 1.05rem;
            font-weight: 700;
            cursor: pointer;
            transition: background 0.2s;
        }
        button[type=submit]:hover { background: #0773c5; }
        .errore {
            background: #fff5f5;
            color: #c0392b;
            border: 1px solid #f5c6cb;
            border-radius: 10px;
            padding: 12px;
            margin-bottom: 20px;
            font-size: 0.9rem;
            text-align: left;
        }
    </style>
</head>
<body>
    <div class="card">
        <div class="logo-wrapper">
            <img src="/logo-belix.png" alt="Belix" />
            <h1>Belix</h1>
        </div>
        <p class="sub">Accedi per continuare</p>

        @if (!string.IsNullOrEmpty(Model.Errore))
        {
            <div class="errore">@Model.Errore</div>
        }

        <form method="post">
            @Html.AntiForgeryToken()
            <label for="username">Username</label>
            <input type="text" id="username" name="username" value="@Model.Username" autocomplete="username" required autofocus />

            <label for="password">Password</label>
            <input type="password" id="password" name="password" autocomplete="current-password" required />

            <button type="submit">Accedi</button>
        </form>
    </div>
</body>
</html>
