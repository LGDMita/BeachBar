@page "/conto/{Id:int}"
@attribute [Authorize]
@inject BeachBar.Infrastructure.Services.ISessioniService Sessioni
@inject BeachBar.Infrastructure.Services.IProdottiService Prodotti
@inject BeachBar.Infrastructure.Services.IConsumazioniService Consumazioni
@inject BeachBar.Services.DateContext DateCtx
@inject BeachBar.Services.IDashboardEventService Events
@inject NavigationManager Nav

<div class="scheda-layout">

    <div class="colonna-sinistra">
        @if (sessione == null && errore == null)
        {
            <p>Caricamento...</p>
        }
        else
        {
            <h2 class="conto-intestazione">
                @(sessione?.OmbrelloneId.HasValue == true ? $"Ombrellone {sessione.Ombrellone?.Numero}" : "Lista Volante")
            </h2>

            @if (sessione != null)
            {
                @* Data o range date *@
                @if (sessione.DataFine.HasValue)
                {
                    <p class="conto-data">
                        📅 @sessione.DataRiferimento?.ToString("dd MMM", ItCulture.IT) –
                        @sessione.DataFine?.ToString("dd MMM yyyy", ItCulture.IT)
                    </p>
                }
                else
                {
                    <p class="conto-data">
                        📅 @((sessione.DataRiferimento ?? DateCtx.DataSelezionata).ToString("dd MMMM yyyy", ItCulture.IT))
                    </p>
                }
            }

            @if (errore != null)
            {
                <div class="alert-errore">⚠️ @errore</div>
            }

            @if (sessione != null)
            {
                <div class="nome-cliente-container">
                    @if (isEditingNome)
                    {
                        <input class="input-nome" @bind="nuovoNome" @onkeyup="@(async (e) => { if (e.Key == "Enter") await SalvaNome(); })" />
                        <button class="btn-salva-nome" @onclick="SalvaNome">✔️</button>
                    }
                    else
                    {
                        <p class="nome-cliente">@(sessione.NomeCliente ?? "Cliente anonimo")</p>
                        <button class="btn-edit" @onclick="IniziaModifica">✏️</button>
                    }
                </div>

                <div class="categorie-tabs">
                    @foreach (var cat in categorie)
                    {
                        <button class="tab @(categoriaSelezionata == cat ? "tab-attivo" : "")"
                                @onclick="() => categoriaSelezionata = cat">
                            @cat
                        </button>
                    }
                </div>

                <div class="prodotti">
                    @foreach (var p in prodottiFiltrati)
                    {
                        <button class="btn-prodotto" @onclick="() => Aggiungi(p.Id)">
                            <span class="prod-nome">@p.Nome</span>
                            <span class="prod-prezzo">€ @p.Prezzo.ToString("0.00")</span>
                        </button>
                    }
                </div>
            }
        }
    </div>

    @if (sessione != null)
    {
        <div class="colonna-destra">
            <h3>Lista</h3>
            <p class="nome-cliente-scontrino">@(sessione.NomeCliente ?? "Cliente anonimo")</p>

            <div class="scontrino-righe">
                @if (!sessione.Consumazioni.Any())
                {
                    <p class="vuoto">Nessun prodotto ancora.</p>
                }
                else
                {
                    @* Raggruppa per giorno — utile per soggiorni multi-giorno *@
                    var giorni = sessione.Consumazioni
                        .GroupBy(c => c.Giorno)
                        .OrderBy(g => g.Key)
                        .ToList();

                    @foreach (var gruppo in giorni)
                    {
                        var totaleGiorno = gruppo.Sum(c => c.Quantita * c.Prodotto.Prezzo);
                        var isOggi = gruppo.Key == DateCtx.DataSelezionata;

                        @if (giorni.Count > 1)
                        {
                            <div class="lista-giorno-header">
                                @gruppo.Key.ToString("dddd dd MMM", ItCulture.IT)
                            </div>
                        }

                        @foreach (var c in gruppo)
                        {
                            <div class="riga-scontrino">
                                <div class="riga-info">
                                    <span class="riga-nome">@c.Prodotto.Nome</span>
                                    <span class="riga-qty">x@(c.Quantita)</span>
                                </div>
                                <div class="riga-destra">
                                    <span class="riga-totale">€ @((c.Quantita * c.Prodotto.Prezzo).ToString("0.00"))</span>
                                    @if (isOggi || !sessione.DataFine.HasValue)
                                    {
                                        <button class="btn-rimuovi" @onclick="() => Rimuovi(c.ProdottoId, gruppo.Key)">−</button>
                                    }
                                </div>
                            </div>
                        }

                        @if (giorni.Count > 1)
                        {
                            <div class="lista-giorno-subtotale">Subtotale: € @totaleGiorno.ToString("0.00")</div>
                        }
                    }
                }
            </div>

            <div class="totale-scontrino">
                Totale: € @sessione.Consumazioni.Sum(c => c.Quantita * c.Prodotto.Prezzo).ToString("0.00")
            </div>

            <div class="azioni-scontrino">
                <button class="btn-torna-dashboard" @onclick='() => Nav.NavigateTo("/")'>
                    Torna alla spiaggia
                </button>
                @if (conferma == ConfermaStato.Nessuna)
                {
                    @if (sessione.OmbrelloneId.HasValue)
                    {
                        <button class="btn-chiudi" @onclick="() => conferma = ConfermaStato.ChiudiOmbrellone">Chiudi ombrellone e incassa</button>
                        <button class="btn-chiudi-lista" @onclick="() => conferma = ConfermaStato.ChiudiLista">Chiudi lista e incassa</button>
                    }
                    else
                    {
                        <button class="btn-chiudi" @onclick='() => ChiudiSessione(false)'>Chiudi e incassa</button>
                    }
                    <button class="btn-annulla btn-annulla-rosso" @onclick="() => conferma = ConfermaStato.Annulla">
                        Annulla lista
                    </button>
                }
                else if (conferma == ConfermaStato.ChiudiOmbrellone)
                {
                    <div class="conferma-pannello conferma-pannello-verde">
                        <p class="conferma-testo conferma-testo-verde">Il conto viene incassato e l'ombrellone liberato.</p>
                        <div class="conferma-bottoni">
                            <button class="conferma-btn-si conferma-btn-verde" @onclick='() => ChiudiSessione(true)'>Conferma</button>
                            <button class="conferma-btn-no" @onclick="() => conferma = ConfermaStato.Nessuna">Annulla</button>
                        </div>
                    </div>
                }
                else if (conferma == ConfermaStato.ChiudiLista)
                {
                    <div class="conferma-pannello conferma-pannello-giallo">
                        <p class="conferma-testo conferma-testo-giallo">Il conto viene incassato. Il posto resta occupato per domani.</p>
                        <div class="conferma-bottoni">
                            <button class="conferma-btn-si conferma-btn-giallo" @onclick='() => ChiudiSessione(false)'>Conferma</button>
                            <button class="conferma-btn-no" @onclick="() => conferma = ConfermaStato.Nessuna">Annulla</button>
                        </div>
                    </div>
                }
                else
                {
                    <div class="conferma-pannello conferma-pannello-arancio">
                        <p class="conferma-testo conferma-testo-giallo">Confermi l'annullamento?</p>
                        <div class="conferma-bottoni">
                            <button class="conferma-btn-si conferma-btn-rosso" @onclick="EseguiAnnulla">Sì</button>
                            <button class="conferma-btn-no" @onclick="() => conferma = ConfermaStato.Nessuna">No</button>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int Id { get; set; }

    private BeachBar.Core.Entities.Sessione? sessione;
    private List<BeachBar.Core.Entities.Prodotto> prodotti = new();
    private string categoriaSelezionata = "";
    private bool isEditingNome;
    private string? nuovoNome;

    // ConfermaStato sostituisce booleani multipli: ogni azione distruttiva mostra
    // un pannello di conferma diverso nello stesso spazio UI senza variabili separate.
    // ChiudiOmbrellone → ChiudiSessioneAsync(liberaOmbrellone: true)  — ombrellone libero
    // ChiudiLista      → ChiudiSessioneAsync(liberaOmbrellone: false) — ombrellone resta occupato
    private enum ConfermaStato { Nessuna, ChiudiOmbrellone, ChiudiLista, Annulla }
    private ConfermaStato conferma = ConfermaStato.Nessuna;
    private string? errore;

    private List<string> categorie => prodotti.Select(p => p.Categoria).Distinct().OrderBy(c => c).ToList();
    private List<BeachBar.Core.Entities.Prodotto> prodottiFiltrati =>
        prodotti.Where(p => p.Categoria == categoriaSelezionata && p.Disponibile).ToList();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            prodotti = await Prodotti.GetProdottiAsync();
            sessione = await Sessioni.GetSessioneByIdAsync(Id);
            if (sessione == null) { errore = $"Lista {Id} non trovata."; return; }
            if (sessione.Chiusa) { errore = "Questa lista è già chiusa."; sessione = null; return; }
            if (categorie.Any()) categoriaSelezionata = categorie.First();
        }
        catch (Exception ex) { errore = $"Impossibile caricare la lista: {ex.Message}"; }
    }

    private void IniziaModifica() { nuovoNome = sessione?.NomeCliente; isEditingNome = true; }

    private async Task SalvaNome()
    {
        if (sessione != null)
        {
            errore = null;
            try { await Sessioni.AggiornaNomeSessioneAsync(sessione.Id, nuovoNome); sessione.NomeCliente = nuovoNome; }
            catch (Exception ex) { errore = $"Impossibile salvare il nome: {ex.Message}"; }
        }
        isEditingNome = false;
    }

    private async Task Aggiungi(int prodottoId)
    {
        errore = null;
        // Aggiornamento ottimistico: modifica il modello locale prima della chiamata DB.
        // L'UI risponde istantaneamente; se il salvataggio fallisce si ripristina dal DB.
        var prodotto = prodotti.First(p => p.Id == prodottoId);
        var oggi = DateCtx.DataSelezionata;
        var existing = sessione!.Consumazioni.FirstOrDefault(c => c.ProdottoId == prodottoId && c.Giorno == oggi);
        if (existing != null)
            existing.Quantita++;
        else
            sessione.Consumazioni.Add(new BeachBar.Core.Entities.Consumazione
            {
                ProdottoId = prodottoId,
                Prodotto = prodotto,
                Quantita = 1,
                Giorno = oggi,
                SessioneId = sessione.Id
            });

        try { await Consumazioni.AggiungiConsumazione(sessione.Id, prodottoId, oggi); }
        catch (Exception ex) { errore = $"Impossibile aggiungere il prodotto: {ex.Message}"; sessione = await Sessioni.GetSessioneByIdAsync(Id); }
    }

    private async Task Rimuovi(int prodottoId, DateOnly giorno)
    {
        errore = null;
        // Aggiornamento ottimistico: modifica locale immediata, rollback su errore.
        var cons = sessione!.Consumazioni.FirstOrDefault(c => c.ProdottoId == prodottoId && c.Giorno == giorno);
        if (cons != null)
        {
            if (cons.Quantita > 1) cons.Quantita--;
            else sessione.Consumazioni.Remove(cons);
        }

        try { await Consumazioni.RimuoviConsumazione(sessione.Id, prodottoId, giorno); }
        catch (Exception ex) { errore = $"Impossibile rimuovere il prodotto: {ex.Message}"; sessione = await Sessioni.GetSessioneByIdAsync(Id); }
    }

    private async Task ChiudiSessione(bool liberaOmbrellone)
    {
        // liberaOmbrellone=true → "Chiudi ombrellone e incassa": il posto torna disponibile subito.
        // liberaOmbrellone=false → "Chiudi lista e incassa": il cliente fisso resta segnato come
        // occupato anche senza lista aperta, pronto per riaprire il giorno successivo.
        errore = null;
        try
        {
            await Sessioni.ChiudiSessioneAsync(sessione!.Id, liberaOmbrellone);
            Events.NotifyStateChanged();
            Nav.NavigateTo("/");
        }
        catch (Exception ex) { errore = $"Impossibile chiudere la lista: {ex.Message}"; }
    }

    private async Task EseguiAnnulla()
    {
        errore = null;
        try
        {
            await Sessioni.AnnullaSessioneAsync(sessione!.Id);
            Events.NotifyStateChanged();
            Nav.NavigateTo("/");
        }
        catch (Exception ex) { conferma = ConfermaStato.Nessuna; errore = $"Impossibile annullare la lista: {ex.Message}"; }
    }
}
