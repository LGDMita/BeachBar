@page "/impostazioni"
@attribute [Authorize]
@inject BeachBar.Infrastructure.Services.IProdottiService Prodotti
@inject BeachBar.Infrastructure.Services.ISessioniService Sessioni
@inject BeachBar.Infrastructure.Services.IImpostazioniService ImpostazioniSvc

<div class="dashboard">
    <h1 class="titolo">Impostazioni</h1>

    <div class="tabs-impostazioni">
        <button class="tab @(sezione == "spiaggia" ? "tab-attivo" : "")" @onclick='() => sezione = "spiaggia"'>🏖️ Spiaggia</button>
        <button class="tab @(sezione == "prodotti" ? "tab-attivo" : "")" @onclick='() => sezione = "prodotti"'>🍹 Prodotti</button>
        <button class="tab @(sezione == "gestione" ? "tab-attivo" : "")" @onclick='() => sezione = "gestione"'>🔧 Gestione</button>
    </div>

    @if (errore != null)
    {
        <div style="background:#f8d7da; color:#721c24; border:1px solid #f5c6cb; padding:10px 14px; border-radius:8px; margin:12px 0;">
            ⚠️ @errore
        </div>
    }

    @if (sezione == "spiaggia")
    {
        <div class="sezione-card">
            <h3>Configurazione ombrelloni</h3>
            <div class="form-riga">
                <label>Numero ombrelloni</label>
                <input type="number" class="input-numero" @bind="numOmbrelloni" min="1" max="100" />
            </div>
            <div class="form-riga">
                <label>Colonne nella griglia</label>
                <input type="number" class="input-numero" @bind="numColonne" min="2" max="8" />
            </div>
            <button class="btn-salva" @onclick="SalvaOmbrelloni">Salva configurazione</button>
            @if (msgSpiaggia != null)
            {
                <p class="msg-ok">@msgSpiaggia</p>
            }
        </div>
    }

    @if (sezione == "prodotti")
    {
        <div class="sezione-card">
            <h3>Categorie</h3>
            <div class="lista-categorie">
                @foreach (var cat in categorie)
                {
                    <div class="riga-categoria">
                        @if (categoriaInModifica == cat)
                        {
                            <input class="input-inline" @bind="nuovoNomeCategoria" />
                            <button class="btn-sm btn-ok" @onclick="() => SalvaCategoria(cat)">✓</button>
                            <button class="btn-sm btn-annulla" @onclick="() => categoriaInModifica = null">✕</button>
                        }
                        else
                        {
                            <span class="cat-nome">@cat</span>
                            <button class="btn-sm btn-modifica" @onclick="() => ModificaCategoria(cat)">✏️</button>
                            <button class="btn-sm btn-elimina" @onclick="() => ConfermaEliminaCategoria(cat)">🗑️</button>
                        }
                    </div>
                }
            </div>

            @if (confermaCancellaCategoria != null)
            {
                <div class="alert-conferma">
                    <p>Eliminare la categoria <strong>@confermaCancellaCategoria</strong> e tutti i suoi prodotti?</p>
                    <button class="btn-conferma-si" @onclick="EliminaCategoria">Sì, elimina</button>
                    <button class="btn-conferma-no" @onclick="() => confermaCancellaCategoria = null">Annulla</button>
                </div>
            }

            <hr />

            <h3>Prodotti</h3>

            <div class="form-nuovo-prodotto">
                <input class="input-testo" placeholder="Nome" @bind="nuovoProdottoNome" />
                <input type="number" class="input-numero" placeholder="Prezzo" @bind="nuovoProdottoPrezzo" step="0.50" />
                <select class="input-select" @bind="nuovoProdottoCategoria">
                    @foreach (var cat in categorie)
                    {
                        <option value="@cat">@cat</option>
                    }
                </select>
                <button class="btn-salva" @onclick="AggiuntaProdotto">+ Aggiungi</button>
            </div>

            <table class="tabella" style="margin-top:16px">
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>Prezzo</th>
                        <th>Categoria</th>
                        <th>Disponibile</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in prodottiLista)
                    {
                        <tr>
                            @if (prodottoInModifica == p.Id)
                            {
                                <td><input class="input-inline" @bind="editNome" /></td>
                                <td><input type="number" class="input-inline" @bind="editPrezzo" step="0.50" /></td>
                                <td>
                                    <select class="input-inline" @bind="editCategoria">
                                        @foreach (var cat in categorie)
                                        {
                                            <option value="@cat">@cat</option>
                                        }
                                    </select>
                                </td>
                                <td><input type="checkbox" @bind="editDisponibile" /></td>
                                <td>
                                    <button class="btn-sm btn-ok" @onclick="() => SalvaProdotto(p.Id)">✓</button>
                                    <button class="btn-sm btn-annulla" @onclick="() => prodottoInModifica = null">✕</button>
                                </td>
                            }
                            else
                            {
                                <td>@p.Nome</td>
                                <td>€ @p.Prezzo.ToString("0.00")</td>
                                <td>@p.Categoria</td>
                                <td>@(p.Disponibile ? "✓" : "—")</td>
                                <td>
                                    <button class="btn-sm btn-modifica" @onclick="() => ModificaProdotto(p)">✏️</button>
                                    <button class="btn-sm btn-elimina" @onclick="() => EliminaProdotto(p.Id)">🗑️</button>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @if (sezione == "gestione")
    {
        <div class="sezione-card">
            <h3>Contatori Dashboard</h3>
            <p>Azzera i contatori dell'incasso odierno nella dashboard. I dati non verranno cancellati e resteranno consultabili nello storico.</p>

            @if (!confermaResetVisivo)
            {
                <button class="btn-chiudi" style="background-color: #ffc107; color: #212529;" @onclick="() => confermaResetVisivo = true">Azzera contatori</button>
            }
            else
            {
                <div class="alert-conferma">
                    <p>Confermi l'azzeramento visivo dei totali?</p>
                    <button class="btn-conferma-si" @onclick="EseguiResetVisivo">Sì, azzera</button>
                    <button class="btn-conferma-no" @onclick="() => confermaResetVisivo = false">Annulla</button>
                </div>
            }

            @if (msgResetVisivo != null)
            {
                <p class="msg-ok">@msgResetVisivo</p>
            }

            <hr style="margin: 30px 0;" />

            <h3>Reset giornaliero (Forzato)</h3>
            <p>Chiude tutte le sessioni aperte e libera tutti gli ombrelloni occupati. Usa questa funzione solo a fine giornata.</p>

            @if (!confermaReset)
            {
                <button class="btn-chiudi" @onclick="() => confermaReset = true">Reset totale sessioni</button>
            }
            else
            {
                <div class="alert-conferma">
                    <p>Sei sicuro? Tutte le sessioni attive verranno chiuse forzatamente.</p>
                    <button class="btn-conferma-si" @onclick="EseguiReset">Sì, resetta tutto</button>
                    <button class="btn-conferma-no" @onclick="() => confermaReset = false">Annulla</button>
                </div>
            }

            @if (msgReset != null)
            {
                <p class="msg-ok">@msgReset</p>
            }

            <hr style="margin: 30px 0;" />

            <h3>Account</h3>
            <p>Termina la sessione corrente e torna alla pagina di login.</p>
            <a href="/logout" class="btn-logout-impostazioni">Esci</a>
        </div>
    }
</div>

@code {
    private string sezione = "spiaggia";

    // Spiaggia
    private int numOmbrelloni;
    private int numColonne;
    private string? msgSpiaggia;

    // Prodotti
    private List<BeachBar.Core.Entities.Prodotto> prodottiLista = new();
    private List<string> categorie = new();
    private string? categoriaInModifica;
    private string? nuovoNomeCategoria;
    private string? confermaCancellaCategoria;
    private string nuovoProdottoNome = "";
    private decimal nuovoProdottoPrezzo;
    private string nuovoProdottoCategoria = "";
    private int? prodottoInModifica;
    private string editNome = "";
    private decimal editPrezzo;
    private string editCategoria = "";
    private bool editDisponibile;

    // Gestione
    private bool confermaReset;
    private string? msgReset;
    private bool confermaResetVisivo;
    private string? msgResetVisivo;

    // Errore generico mostrato sopra alla sezione attiva
    private string? errore;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var imp = await ImpostazioniSvc.GetImpostazioniAsync();
            numOmbrelloni = imp.NumeroOmbrelloni;
            numColonne = imp.NumeroColonne;
            await CaricaProdotti();
        }
        catch (Exception ex)
        {
            errore = $"Impossibile caricare le impostazioni: {ex.Message}";
        }
    }

    // Nessun try-catch qui: le eccezioni devono propagarsi ai metodi chiamanti
    // che hanno il proprio contesto di errore e il proprio catch block.
    private async Task CaricaProdotti()
    {
        prodottiLista = await Prodotti.GetTuttiProdottiAsync();
        categorie = await Prodotti.GetCategorieAsync();
    }

    private async Task SalvaOmbrelloni()
    {
        errore = null;
        msgSpiaggia = null;
        try
        {
            await ImpostazioniSvc.AggiornaOmbrelloniAsync(numOmbrelloni);
            await ImpostazioniSvc.AggiornaColumeAsync(numColonne);
            msgSpiaggia = "Configurazione salvata.";
        }
        catch (Exception ex)
        {
            errore = $"Errore nel salvataggio della configurazione: {ex.Message}";
        }
    }

    private void ModificaCategoria(string cat)
    {
        categoriaInModifica = cat;
        nuovoNomeCategoria = cat;
    }

    private async Task SalvaCategoria(string vecchia)
    {
        errore = null;
        try
        {
            if (!string.IsNullOrWhiteSpace(nuovoNomeCategoria))
                await Prodotti.RinominaCategoriaAsync(vecchia, nuovoNomeCategoria!);
            categoriaInModifica = null;
            await CaricaProdotti();
        }
        catch (Exception ex)
        {
            categoriaInModifica = null;
            errore = $"Errore nel rinominare la categoria: {ex.Message}";
        }
    }

    private void ConfermaEliminaCategoria(string cat) => confermaCancellaCategoria = cat;

    private async Task EliminaCategoria()
    {
        errore = null;
        try
        {
            await Prodotti.EliminaCategoriaAsync(confermaCancellaCategoria!);
            confermaCancellaCategoria = null;
            await CaricaProdotti();
        }
        catch (Exception ex)
        {
            confermaCancellaCategoria = null;
            errore = $"Errore nell'eliminazione della categoria: {ex.Message}";
        }
    }

    private async Task AggiuntaProdotto()
    {
        if (string.IsNullOrWhiteSpace(nuovoProdottoNome)) return;
        errore = null;
        try
        {
            await Prodotti.AggiuntaProdottoAsync(nuovoProdottoNome, nuovoProdottoPrezzo, nuovoProdottoCategoria);
            nuovoProdottoNome = "";
            nuovoProdottoPrezzo = 0;
            await CaricaProdotti();
        }
        catch (Exception ex)
        {
            errore = $"Errore nell'aggiunta del prodotto: {ex.Message}";
        }
    }

    private void ModificaProdotto(BeachBar.Core.Entities.Prodotto p)
    {
        prodottoInModifica = p.Id;
        editNome = p.Nome;
        editPrezzo = p.Prezzo;
        editCategoria = p.Categoria;
        editDisponibile = p.Disponibile;
    }

    private async Task SalvaProdotto(int id)
    {
        errore = null;
        try
        {
            await Prodotti.AggiornaProdottoAsync(id, editNome, editPrezzo, editCategoria, editDisponibile);
            prodottoInModifica = null;
            await CaricaProdotti();
        }
        catch (Exception ex)
        {
            prodottoInModifica = null;
            errore = $"Errore nel salvataggio del prodotto: {ex.Message}";
        }
    }

    private async Task EliminaProdotto(int id)
    {
        errore = null;
        try
        {
            await Prodotti.EliminaProdottoAsync(id);
            await CaricaProdotti();
        }
        catch (Exception ex)
        {
            errore = $"Errore nell'eliminazione del prodotto: {ex.Message}";
        }
    }

    private async Task EseguiReset()
    {
        errore = null;
        msgReset = null;
        try
        {
            await Sessioni.ResetTotaliAsync();
            confermaReset = false;
            msgReset = "Reset sessioni completato.";
        }
        catch (Exception ex)
        {
            confermaReset = false;
            errore = $"Errore durante il reset: {ex.Message}";
        }
    }

    private async Task EseguiResetVisivo()
    {
        errore = null;
        msgResetVisivo = null;
        try
        {
            await ImpostazioniSvc.ResetVisivoStatisticheAsync();
            confermaResetVisivo = false;
            msgResetVisivo = "Contatori dashboard azzerati.";
        }
        catch (Exception ex)
        {
            confermaResetVisivo = false;
            errore = $"Errore nell'azzeramento dei contatori: {ex.Message}";
        }
    }
}
