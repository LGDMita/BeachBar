@page "/impostazioni"
@attribute [Authorize]
@implements IAsyncDisposable
@inject BeachBar.Infrastructure.Services.IProdottiService Prodotti
@inject BeachBar.Infrastructure.Services.ISessioniService Sessioni
@inject BeachBar.Infrastructure.Services.IImpostazioniService ImpostazioniSvc
@inject IJSRuntime JS

<div class="dashboard">
    <h1 class="titolo">Impostazioni</h1>

    <div class="tabs-impostazioni">
        <button class="tab @(sezione == "spiaggia" ? "tab-attivo" : "")" @onclick='() => sezione = "spiaggia"'>🏖️ Spiaggia</button>
        <button class="tab @(sezione == "prodotti" ? "tab-attivo" : "")" @onclick='() => sezione = "prodotti"'>🍹 Prodotti</button>
        <button class="tab @(sezione == "gestione" ? "tab-attivo" : "")" @onclick='() => sezione = "gestione"'>🔧 Gestione</button>
    </div>

    @if (errore != null)
    {
        <div class="alert-errore">⚠️ @errore</div>
    }

    @if (sezione == "spiaggia")
    {
        <div class="sezione-card">
            <h3>Dimensioni griglia</h3>
            <p class="sezione-desc">Imposta quante righe e colonne ha la mappa della spiaggia. Cambiare le dimensioni azzera le posizioni già assegnate — gli ombrelloni rimangono nel sistema ma vanno riposizionati.</p>
            <div class="form-riga">
                <label>Righe</label>
                <input type="number" class="input-numero" @bind="tempRighe" min="1" max="20" />
            </div>
            <div class="form-riga">
                <label>Colonne</label>
                <input type="number" class="input-numero" @bind="tempColonne" min="1" max="16" />
            </div>
            <p class="help-dim">⚠️ Cambiare le dimensioni azzera tutte le posizioni e i bordi fuori dai nuovi limiti.</p>

            @if (confermaDimensioni)
            {
                <div class="alert-conferma" style="margin-top:12px;">
                    <span>Il layout attuale verrà azzerato. Continuare?</span>
                    <button class="btn-conferma-si" @onclick="ApplicaDimensioni">Sì, ridimensiona</button>
                    <button class="btn-conferma-no" @onclick="() => { confermaDimensioni = false; tempRighe = numRighe; tempColonne = numColonne; }">Annulla</button>
                </div>
            }
            else
            {
                <button class="btn-salva" @onclick="ClickApplicaDimensioni">Applica dimensioni</button>
            }

            @if (msgSpiaggia != null)
            {
                <p class="msg-ok">✓ @msgSpiaggia</p>
            }
        </div>

        <div class="sezione-card sezione-card-mappa">
            <div class="editor-header">
                <div>
                    <h3 style="margin:0 0 4px;">Mappa ombrelloni</h3>
                    <p class="sezione-desc" style="margin:0;">Clicca o trascina sulle celle vuote per posizionare gli ombrelloni. Le celle non occupate vengono comunque mostrate sulla dashboard come quadrati grigi, a indicare lo spazio disponibile.</p>
                </div>
                <div class="editor-status">
                    <span class="status-chip status-ok">@celleOccupate / @(numRighe * numColonne) celle</span>
                    @if (!modalitaCancella && celleOccupate < numRighe * numColonne)
                    {
                        <span class="status-chip status-next">Prossimo: <strong>#@ProssimoNumero</strong></span>
                    }
                </div>
            </div>

            <div class="editor-toolbar">
                <div class="editor-help-text">
                    @if (modalitaCancella)
                    {
                        <span>🗑️ <strong>Modalità cancella:</strong> clicca su un ombrellone per rimuoverlo</span>
                    }
                    else
                    {
                        <span>Click su cella vuota = posiziona · Click destro su cella piena = rimuovi · Click sul separatore = bordo</span>
                    }
                </div>
                <button class="mode-toggle @(modalitaCancella ? "mode-toggle-on" : "")"
                        @onclick="() => modalitaCancella = !modalitaCancella"
                        title="@(modalitaCancella ? "Disattiva modalità cancella" : "Attiva modalità cancella (utile su touch screen)")">
                    @(modalitaCancella ? "✕ Cancella ON" : "✕ Cancella")
                </button>
            </div>

            <div class="editor-outer">
              <div class="editor-scroll-inner">
                @* Riga etichette colonne *@
                <div class="editor-col-header">
                    <div class="editor-corner-spacer"></div>
                    @for (int c = 0; c < numColonne; c++)
                    {
                        <div class="editor-label-cell-col">@(c + 1)</div>
                        @if (c < numColonne - 1) { <div class="editor-label-gap-h"></div> }
                    }
                </div>

                @* Griglia + etichette righe *@
                <div class="editor-main">
                    <div class="editor-row-labels">
                        @for (int r = 0; r < numRighe; r++)
                        {
                            <div class="editor-label-cell-row">@(r + 1)</div>
                            @if (r < numRighe - 1) { <div class="editor-label-gap-v"></div> }
                        }
                    </div>

                    <div class="editor-scroll-x">
                        <div class="layout-editor @(modalitaCancella ? "modalita-cancella" : "")"
                             style="@EditorGridStyle"
                             @ref="_editorRef">
                            @for (int r = 0; r < numRighe; r++)
                            {
                                @for (int c = 0; c < numColonne; c++)
                                {
                                    int idx = r * numColonne + c;
                                    var omb = idx < celleEditor.Length ? celleEditor[idx] : null;

                                    <div class="editor-cell @(omb != null ? "cell-piena" : "cell-vuota")"
                                         data-cell-idx="@idx"
                                         @onclick="() => GestioneClickCella(idx)"
                                         @oncontextmenu:preventDefault="true"
                                         @oncontextmenu="() => RimuoviDaCellaEditor(idx)"
                                         title="@(omb != null ? $"Ombrellone #{omb.Numero} · click destro per rimuovere" : "Clicca per posizionare")">
                                        @if (omb != null)
                                        {
                                            <span class="cell-num">@omb.Numero</span>
                                        }
                                        else if (!modalitaCancella)
                                        {
                                            <span class="cell-hint">+</span>
                                        }
                                    </div>

                                    @if (c < numColonne - 1)
                                    {
                                        int sepC = c;
                                        bool vOn = bordiV.Contains(sepC);
                                        <div class="editor-sep editor-sep-v @(vOn ? "sep-on" : "sep-off")"
                                             title="@(vOn ? "Rimuovi bordo verticale" : "Aggiungi bordo verticale")"
                                             @onclick="() => ToggleBordoV(sepC)">
                                            <div class="sep-inner"></div>
                                        </div>
                                    }
                                }

                                @if (r < numRighe - 1)
                                {
                                    int sepR = r;
                                    bool hOn = bordiH.Contains(sepR);

                                    @for (int c = 0; c < numColonne; c++)
                                    {
                                        <div class="editor-sep editor-sep-h @(hOn ? "sep-on" : "sep-off")"
                                             title="@(hOn ? "Rimuovi bordo orizzontale" : "Aggiungi bordo orizzontale")"
                                             @onclick="() => ToggleBordoH(sepR)">
                                            <div class="sep-inner"></div>
                                        </div>

                                        @if (c < numColonne - 1)
                                        {
                                            int localC = c;
                                            bool cornerOn = bordiV.Contains(localC) && hOn;
                                            <div class="editor-corner @(cornerOn ? "corner-on" : "")"></div>
                                        }
                                    }
                                }
                            }
                        </div>
                    </div>
                </div>
              </div>
            </div>

            @if (ombrelloniNonPosizionati.Count > 0)
            {
                <div class="pool-info">
                    <span class="pool-count">@ombrelloniNonPosizionati.Count non posizionati</span>
                    <span class="pool-list">
                        (@string.Join(", ", ombrelloniNonPosizionati.Take(10).Select(o => "#" + o.Numero))@(ombrelloniNonPosizionati.Count > 10 ? "..." : ""))
                    </span>
                    <span class="pool-hint">Il click su cella vuota li assegna in ordine</span>
                </div>
            }

            <div class="editor-azioni">
                <button class="btn-azione" @onclick="PopolaSequenziale" title="Riempie tutta la griglia con ombrelloni numerati in sequenza (crea i mancanti)">
                    ⚡ Popola griglia intera
                </button>
                @if (!confermaAzzeraLayout)
                {
                    <button class="btn-azione btn-azione-danger" @onclick="() => confermaAzzeraLayout = true">
                        🗑️ Azzera posizioni
                    </button>
                }
                else
                {
                    <span class="conferma-inline">
                        Rimuovere tutti dalla griglia?
                        <button class="btn-conferma-si" style="padding:6px 14px;" @onclick="EseguiAzzeraLayout">Sì</button>
                        <button class="btn-conferma-no" style="padding:6px 14px;" @onclick="() => confermaAzzeraLayout = false">No</button>
                    </span>
                }
            </div>
        </div>
    }

    @if (sezione == "prodotti")
    {
        @* ── Gestione categorie ── *@
        <div class="sezione-card">
            <h3>Categorie</h3>
            <p class="sezione-desc">Aggiungi, rinomina o elimina le categorie. Eliminare una categoria rimuove anche tutti i prodotti al suo interno.</p>
            <div class="lista-categorie">
                @foreach (var cat in categorie)
                {
                    <div class="riga-categoria">
                        @if (categoriaInModifica == cat)
                        {
                            <input class="input-inline" @bind="nuovoNomeCategoria" />
                            <button class="btn-sm btn-ok" @onclick="() => SalvaCategoria(cat)">✓</button>
                            <button class="btn-sm btn-annulla" @onclick="() => categoriaInModifica = null">✕</button>
                        }
                        else
                        {
                            <span class="cat-nome">@cat</span>
                            <button class="btn-sm btn-modifica" @onclick="() => ModificaCategoria(cat)">✏️</button>
                            <button class="btn-sm btn-elimina" @onclick="() => ConfermaEliminaCategoria(cat)">🗑️</button>
                        }
                    </div>
                }
                <div class="riga-categoria riga-nuova-categoria">
                    <input class="input-inline" placeholder="Nuova categoria..." @bind="nuovaCategoriaInput" @onkeydown="NuovaCategoriaKeyDown" />
                    <button class="btn-sm btn-ok" @onclick="AggiungiCategoria">+</button>
                </div>
            </div>
            @if (confermaCancellaCategoria != null)
            {
                <div class="alert-conferma">
                    <p>Eliminare la categoria <strong>@confermaCancellaCategoria</strong> e tutti i suoi prodotti?</p>
                    <button class="btn-conferma-si" @onclick="EliminaCategoria">Sì, elimina</button>
                    <button class="btn-conferma-no" @onclick="() => confermaCancellaCategoria = null">Annulla</button>
                </div>
            }
        </div>

        @* ── Aggiungi nuovo prodotto ── *@
        <div class="sezione-card aggiungi-prodotto-card">
            <h3>Aggiungi prodotto</h3>
            <div class="form-nuovo-prodotto">
                <div class="campo-prodotto campo-prodotto-nome">
                    <label class="campo-label">Nome</label>
                    <input class="input-testo" placeholder="es. Birra Media" @bind="nuovoProdottoNome" />
                </div>
                <div class="campo-prodotto">
                    <label class="campo-label">Prezzo (€)</label>
                    <div class="input-con-prefisso">
                        <span class="input-prefisso">€</span>
                        <input type="number" class="input-numero" placeholder="0.00" @bind="nuovoProdottoPrezzo" step="0.01" min="0" />
                    </div>
                </div>
                <div class="campo-prodotto">
                    <label class="campo-label">Categoria</label>
                    <select class="input-select" @bind="nuovoProdottoCategoria">
                        @foreach (var cat in categorie)
                        {
                            <option value="@cat">@cat</option>
                        }
                    </select>
                </div>
                <div class="campo-prodotto campo-prodotto-azione">
                    <label class="campo-label">&nbsp;</label>
                    <button class="btn-salva" style="margin-top:0;" @onclick="AggiuntaProdotto">+ Aggiungi</button>
                </div>
            </div>
        </div>

        @* ── Lista prodotti per categoria ── *@
        <div class="sezione-card">
            <div class="prodotti-toolbar">
                <input class="prodotti-search"
                       type="search"
                       placeholder="Cerca prodotto per nome..."
                       @bind-value="prodottoFiltro"
                       @bind-value:event="oninput" />
                <span class="prodotti-count">@ProdottiVisibili.Count() prodotti</span>
            </div>
            <div class="prodotti-filtri">
                <button class="chip @(filtroCat == "" ? "chip-on" : "")" @onclick='() => filtroCat = ""'>Tutte</button>
                @foreach (var cat in categorie)
                {
                    <button class="chip @(filtroCat == cat ? "chip-on" : "")" @onclick='() => filtroCat = cat'>@cat</button>
                }
            </div>

            @foreach (var cat in CategorieVisibili)
            {
                var prodCat = ProdottiVisibili.Where(p => p.Categoria == cat).ToList();
                if (!prodCat.Any()) continue;

                <div class="prodotti-cat-sezione">
                    <div class="prodotti-cat-header">
                        <span class="prodotti-cat-titolo">@cat</span>
                        <span class="prodotti-cat-count">@prodCat.Count</span>
                    </div>
                    <div class="prodotti-griglia">
                        @foreach (var p in prodCat)
                        {
                            @if (prodottoInModifica == p.Id)
                            {
                                <div class="prodotto-card prodotto-card-edit">
                                    <input class="input-inline" @bind="editNome" placeholder="Nome" />
                                    <div class="prodotto-edit-row">
                                        <div class="input-con-prefisso" style="flex:0 0 90px;">
                                            <span class="input-prefisso">€</span>
                                            <input type="number" class="input-inline" @bind="editPrezzo" step="0.01" style="padding-left:22px;" />
                                        </div>
                                        <select class="input-inline" @bind="editCategoria" style="flex:1;">
                                            @foreach (var c in categorie)
                                            {
                                                <option value="@c">@c</option>
                                            }
                                        </select>
                                    </div>
                                    <label class="prodotto-disp-check">
                                        <input type="checkbox" @bind="editDisponibile" />
                                        <span>Disponibile</span>
                                    </label>
                                    <div class="prodotto-card-azioni">
                                        <button class="btn-sm btn-ok" @onclick="() => SalvaProdotto(p.Id)">✓ Salva</button>
                                        <button class="btn-sm btn-annulla" @onclick="() => prodottoInModifica = null">✕</button>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="prodotto-card @(p.Disponibile ? "" : "prodotto-non-disp")">
                                    <div class="prodotto-header">
                                        <span class="prodotto-nome">@p.Nome</span>
                                        <span class="prodotto-prezzo-badge">€ @p.Prezzo.ToString("0.00")</span>
                                    </div>
                                    <div class="prodotto-meta">
                                        <span class="@(p.Disponibile ? "prodotto-disp-si" : "prodotto-disp-no")">
                                            @(p.Disponibile ? "disponibile" : "non disp.")
                                        </span>
                                    </div>
                                    <div class="prodotto-card-azioni">
                                        <button class="btn-sm btn-modifica" @onclick="() => ModificaProdotto(p)">✏️</button>
                                        <button class="btn-sm btn-elimina" @onclick="() => EliminaProdotto(p.Id)">🗑️</button>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            }
        </div>
    }

    @if (sezione == "gestione")
    {
        <div class="sezione-card">
            <p class="sezione-desc">Operazioni di fine giornata e gestione dell'account.</p>
            <h3>Contatori Dashboard</h3>
            <p>Azzera il punto di partenza dei contatori "Totale aperto" e "Incassato oggi" senza toccare i dati. I conti rimangono aperti e lo storico è invariato — utile dopo una cassa intermedia.</p>

            @if (!confermaResetVisivo)
            {
                <button class="btn-chiudi" style="background-color: #ffc107; color: #212529;" @onclick="() => confermaResetVisivo = true">Azzera contatori</button>
            }
            else
            {
                <div class="alert-conferma">
                    <p>Confermi l'azzeramento visivo dei totali?</p>
                    <button class="btn-conferma-si" @onclick="EseguiResetVisivo">Sì, azzera</button>
                    <button class="btn-conferma-no" @onclick="() => confermaResetVisivo = false">Annulla</button>
                </div>
            }
            @if (msgResetVisivo != null) { <p class="msg-ok">@msgResetVisivo</p> }

            <hr style="margin: 30px 0;" />

            <h3>Reset giornaliero (Forzato)</h3>
            <p>Chiude forzatamente tutte le sessioni ancora aperte e libera gli ombrelloni. Usa questa funzione solo a fine giornata se qualche conto è rimasto aperto per errore.</p>

            @if (!confermaReset)
            {
                <button class="btn-chiudi" @onclick="() => confermaReset = true">Reset totale sessioni</button>
            }
            else
            {
                <div class="alert-conferma">
                    <p>Sei sicuro? Tutte le sessioni attive verranno chiuse forzatamente.</p>
                    <button class="btn-conferma-si" @onclick="EseguiReset">Sì, resetta tutto</button>
                    <button class="btn-conferma-no" @onclick="() => confermaReset = false">Annulla</button>
                </div>
            }
            @if (msgReset != null) { <p class="msg-ok">@msgReset</p> }

            <hr style="margin: 30px 0;" />

            <h3>Account</h3>
            <p>Termina la sessione corrente e torna alla pagina di login.</p>
            <a href="/logout" class="btn-logout-impostazioni">Esci</a>
        </div>
    }
</div>

@code {
    private string sezione = "spiaggia";

    // ── Spiaggia / layout ─────────────────────────────────────────────────
    private int numRighe = 5;
    private int numColonne = 4;
    private int tempRighe = 5;
    private int tempColonne = 4;
    private int numOmbrelloni;
    private HashSet<int> bordiV = new();
    private HashSet<int> bordiH = new();
    private BeachBar.Core.Entities.Ombrellone?[] celleEditor = Array.Empty<BeachBar.Core.Entities.Ombrellone?>();
    private List<BeachBar.Core.Entities.Ombrellone> ombrelloniNonPosizionati = new();
    private bool modalitaCancella;
    private bool confermaAzzeraLayout;
    private bool confermaDimensioni;
    private string? msgSpiaggia;
    private int _msgVersion;

    private int celleOccupate => celleEditor.Count(c => c != null);
    private bool LayoutHasCelle => celleEditor.Any(c => c != null);

    private int ProssimoNumero =>
        ombrelloniNonPosizionati.Count > 0
            ? ombrelloniNonPosizionati[0].Numero
            : (celleEditor.Any(c => c != null)
                ? celleEditor.Where(c => c != null).Max(c => c!.Numero) + 1
                : 1);

    private string EditorGridStyle =>
        "display:grid;" +
        "grid-template-columns:" + string.Join(" ", Enumerable.Range(0, 2 * numColonne - 1).Select(i => i % 2 == 0 ? "52px" : "12px")) + ";" +
        "grid-template-rows:" + string.Join(" ", Enumerable.Range(0, 2 * numRighe - 1).Select(i => i % 2 == 0 ? "44px" : "12px")) + ";" +
        "gap:0;width:fit-content;";

    private static HashSet<int> ParseBordi(string? s) =>
        s == null
            ? new()
            : s.Split(',', StringSplitOptions.RemoveEmptyEntries)
               .Where(x => int.TryParse(x, out _))
               .Select(int.Parse)
               .ToHashSet();

    // ── Prodotti ──────────────────────────────────────────────────────────
    private List<BeachBar.Core.Entities.Prodotto> prodottiLista = new();
    private List<string> categorie = new();
    private string prodottoFiltro = "";
    private string filtroCat = "";
    private string? categoriaInModifica;
    private string? nuovoNomeCategoria;
    private string nuovaCategoriaInput = "";
    private string? confermaCancellaCategoria;
    private string nuovoProdottoNome = "";
    private decimal nuovoProdottoPrezzo;
    private string nuovoProdottoCategoria = "";
    private int? prodottoInModifica;
    private string editNome = "";
    private decimal editPrezzo;
    private string editCategoria = "";
    private bool editDisponibile;

    private IEnumerable<BeachBar.Core.Entities.Prodotto> ProdottiVisibili =>
        prodottiLista
            .Where(p => string.IsNullOrEmpty(filtroCat) || p.Categoria == filtroCat)
            .Where(p => string.IsNullOrWhiteSpace(prodottoFiltro) ||
                        p.Nome.Contains(prodottoFiltro, StringComparison.OrdinalIgnoreCase));

    private IEnumerable<string> CategorieVisibili =>
        string.IsNullOrEmpty(filtroCat) ? categorie : categorie.Where(c => c == filtroCat);

    // ── Gestione ──────────────────────────────────────────────────────────
    private bool confermaReset;
    private string? msgReset;
    private bool confermaResetVisivo;
    private string? msgResetVisivo;
    private string? errore;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await CaricaLayoutEditor();
            await CaricaProdotti();
        }
        catch (Exception ex)
        {
            errore = $"Impossibile caricare le impostazioni: {ex.Message}";
        }
    }

    private async Task CaricaLayoutEditor()
    {
        var imp = await ImpostazioniSvc.GetImpostazioniAsync();
        numOmbrelloni = imp.NumeroOmbrelloni;
        numColonne = imp.NumeroColonne;
        numRighe = imp.NumeroRighe;
        tempColonne = numColonne;
        tempRighe = numRighe;
        bordiV = ParseBordi(imp.BordiVerticali);
        bordiH = ParseBordi(imp.BordiOrizzontali);

        var tutti = await ImpostazioniSvc.GetOmbrelloniPerEditorAsync();
        int totCelle = numRighe * numColonne;
        celleEditor = new BeachBar.Core.Entities.Ombrellone?[totCelle];
        ombrelloniNonPosizionati = new();

        foreach (var o in tutti)
        {
            if (o.CellaIndice.HasValue && o.CellaIndice.Value < totCelle)
                celleEditor[o.CellaIndice.Value] = o;
            else
                ombrelloniNonPosizionati.Add(o); // include sia non posizionati che fuori bounds
        }
    }

    private void SetMsg(string msg)
    {
        msgSpiaggia = msg;
        int v = ++_msgVersion;
        _ = ClearMsgAsync(v);
    }

    private async Task ClearMsgAsync(int version)
    {
        await Task.Delay(3500);
        if (_msgVersion == version)
        {
            msgSpiaggia = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ClickApplicaDimensioni()
    {
        bool dimensioniCambiate = tempRighe != numRighe || tempColonne != numColonne;
        if (dimensioniCambiate && LayoutHasCelle)
        {
            confermaDimensioni = true;
        }
        else
        {
            await ApplicaDimensioni();
        }
    }

    private async Task ApplicaDimensioni()
    {
        errore = null;
        confermaDimensioni = false;
        try
        {
            await ImpostazioniSvc.AggiornaGrigliaAsync(tempRighe, tempColonne);
            await CaricaLayoutEditor();
            SetMsg($"Griglia ridimensionata a {numRighe}×{numColonne}.");
        }
        catch (Exception ex)
        {
            errore = $"Errore: {ex.Message}";
        }
    }

    // ── Drag JS (mouse + touch tramite pointer events) ────────────────────
    private ElementReference _editorRef;
    private DotNetObjectReference<Impostazioni>? _dotNetRef;
    private bool _dragJsReady;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (sezione == "spiaggia" && !_dragJsReady)
        {
            _dragJsReady = true;
            _dotNetRef ??= DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("belix.editorDrag.init", _dotNetRef, _editorRef);
        }
        else if (sezione != "spiaggia" && _dragJsReady)
        {
            _dragJsReady = false;
            await JS.InvokeVoidAsync("belix.editorDrag.dispose");
        }
    }

    [JSInvokable]
    public async Task CompletaDragJS(int[] indici)
    {
        if (indici.Length == 0) return;
        errore = null;
        try
        {
            await ImpostazioniSvc.AssegnaCelleAsync(indici);
            await CaricaLayoutEditor();
        }
        catch (Exception ex)
        {
            errore = $"Errore: {ex.Message}";
            await CaricaLayoutEditor();
        }
        await InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("belix.editorDrag.dispose"); } catch { }
        _dotNetRef?.Dispose();
    }

    private async Task GestioneClickCella(int idx)
    {
        if (modalitaCancella)
            await RimuoviDaCellaEditor(idx);
        else
            await ClickCellaEditor(idx);
    }

    private async Task ClickCellaEditor(int idx)
    {
        if (idx < celleEditor.Length && celleEditor[idx] != null) return;
        errore = null;
        try
        {
            await ImpostazioniSvc.AssegnaCellaAsync(idx);
            await CaricaLayoutEditor();
        }
        catch (Exception ex)
        {
            errore = $"Errore: {ex.Message}";
        }
    }

    private async Task RimuoviDaCellaEditor(int idx)
    {
        if (idx >= celleEditor.Length || celleEditor[idx] == null) return;
        errore = null;
        try
        {
            await ImpostazioniSvc.RimuoviDaCellaAsync(idx);
            await CaricaLayoutEditor();
        }
        catch (Exception ex)
        {
            errore = $"Errore: {ex.Message}";
        }
    }

    private async Task ToggleBordoV(int col)
    {
