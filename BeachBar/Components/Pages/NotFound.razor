@page "/not-found"
@layout MainLayout
@inject NavigationManager Nav

<div style="display:flex; flex-direction:column; align-items:center; justify-content:center; min-height:70vh; text-align:center; padding:24px;">
    <div style="font-size:5rem; margin-bottom:16px;">🏖️</div>
    <h1 style="font-size:4rem; font-weight:800; color:#dee2e6; margin:0;">404</h1>
    <h2 style="font-size:1.4rem; font-weight:600; color:#495057; margin:12px 0 8px;">Pagina non trovata</h2>
    <p style="color:#6c757d; margin-bottom:32px;">L'indirizzo che hai cercato non esiste o è stato spostato.</p>
    <button @onclick='() => Nav.NavigateTo("/")'
            style="padding:12px 28px; background:#007bff; color:white; border:none; border-radius:12px; font-size:1rem; font-weight:600; cursor:pointer;">
        🏠 Torna alla dashboard
    </button>
</div>
