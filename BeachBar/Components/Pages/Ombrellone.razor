@page "/ombrellone/{Id:int}"
@attribute [Authorize]
@inject BeachBar.Infrastructure.Services.ISessioniService Sessioni
@inject BeachBar.Services.DateContext DateCtx
@inject NavigationManager Nav
@using System.Globalization

<div class="dashboard ombrellone-pagina">
    <h2 class="ombrellone-titolo">Ombrellone @Id</h2>
    <p class="ombrellone-data">📅 @DateCtx.DataSelezionata.ToString("dd MMMM yyyy", new CultureInfo("it-IT"))</p>

    @if (errore != null)
    {
        <div class="alert-errore">⚠️ @errore</div>
    }

    @if (ombrelloneValido && sessioni != null)
    {
        @if (sessioni.Any())
        {
            <h3 class="ombrellone-sezione">Liste aperte</h3>
            @foreach (var s in sessioni)
            {
                var totale = s.Consumazioni.Sum(c => c.Quantita * c.Prodotto.Prezzo);
                var nProdotti = s.Consumazioni.Sum(c => c.Quantita);
                var dataRange = s.DataFine.HasValue
                    ? $"{s.DataRiferimento?.ToString("dd MMM", new CultureInfo("it-IT"))} – {s.DataFine?.ToString("dd MMM", new CultureInfo("it-IT"))}"
                    : s.DataRiferimento?.ToString("dd MMMM", new CultureInfo("it-IT"));

                <div class="lista-card">
                    <div class="lista-card-info">
                        <div class="lista-card-nome">@(string.IsNullOrWhiteSpace(s.NomeCliente) ? "Ospite" : s.NomeCliente)</div>
                        <div class="lista-card-meta">
                            @dataRange · @nProdotti prodotti · € @totale.ToString("0.00")
                        </div>
                    </div>
                    <button class="btn-lista-apri" @onclick='() => Nav.NavigateTo("/conto/" + s.Id)'>
                        Gestisci →
                    </button>
                </div>
            }
            <hr class="ombrellone-hr" />
        }

        <h3 class="ombrellone-sezione">@(sessioni.Any() ? "Nuova lista" : "Ombrellone libero")</h3>

        <div class="nuova-lista-form">
            <input class="input-nome" placeholder="Nome cliente (opzionale)" @bind="nomeCliente" />

            <div class="giorni-row">
                <label class="giorni-label">Giorni di soggiorno</label>
                <input type="number" class="input-giorni" @bind="numGiorni" min="1" max="30" />
                @if (numGiorni > 1)
                {
                    <span class="giorni-hint">
                        fino al @DateCtx.DataSelezionata.AddDays(numGiorni - 1).ToString("dd MMM", new CultureInfo("it-IT"))
                    </span>
                }
            </div>

            <button class="btn-apri-lista" @onclick="ApriSessione">
                @(DateCtx.IsOggi ? "Apri lista" : "Prenota")
            </button>
        </div>

        <button class="btn-torna-spiaggia" @onclick='() => Nav.NavigateTo("/")'>
            ← Torna alla spiaggia
        </button>
    }
    else if (ombrelloneValido && sessioni == null)
    {
        <p class="caricamento">Caricamento...</p>
    }
</div>

@code {
    [Parameter] public int Id { get; set; }

    private List<BeachBar.Core.Entities.Sessione>? sessioni;
    private string? nomeCliente;
    private int numGiorni = 1;
    private bool ombrelloneValido = true;
    private string? errore;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var ombrellone = await Sessioni.GetOmbrelloneByIdAsync(Id);
            if (ombrellone == null)
            {
                ombrelloneValido = false;
                errore = $"Ombrellone {Id} non trovato.";
                return;
            }
            sessioni = await Sessioni.GetSessioniAttivePerOmbrelloneAsync(Id, DateCtx.DataSelezionata);
        }
        catch (Exception ex)
        {
            ombrelloneValido = false;
            errore = $"Impossibile caricare i dati: {ex.Message}";
        }
    }

    private async Task ApriSessione()
    {
        errore = null;
        try
        {
            var nuova = await Sessioni.ApriSessioneAsync(Id, nomeCliente, DateCtx.DataSelezionata, numGiorni);
            Nav.NavigateTo("/conto/" + nuova.Id);
        }
        catch (Exception ex)
        {
            errore = $"Impossibile aprire la lista: {ex.Message}";
        }
    }
}
