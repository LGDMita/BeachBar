@page "/ombrellone/{Id:int}"
@attribute [Authorize]
@inject BeachBar.Infrastructure.Services.ISessioniService Sessioni
@inject BeachBar.Services.DateContext DateCtx
@inject NavigationManager Nav

<div class="dashboard" style="max-width: 600px; margin: 0 auto;">
    <h2>Ombrellone @Id</h2>
    <div style="font-size: 0.85rem; color: #6c757d; margin-bottom: 16px;">
        📅 @DateCtx.DataSelezionata.ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("it-IT"))
    </div>

    @if (errore != null)
    {
        <div style="background:#f8d7da; color:#721c24; border:1px solid #f5c6cb; padding:10px 14px; border-radius:8px; margin-bottom:12px;">
            ⚠️ @errore
        </div>
    }

    @if (ombrelloneValido)
    {
        @if (sessioni == null)
        {
            <p>Caricamento...</p>
        }
        else
        {
            @if (sessioni.Any())
            {
                <h3 style="margin-bottom: 12px;">Conti aperti</h3>
                @foreach (var s in sessioni)
                {
                    var totale = s.Consumazioni.Sum(c => c.Quantita * c.Prodotto.Prezzo);
                    <div style="background: white; border-radius: 12px; padding: 16px; margin-bottom: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); display: flex; justify-content: space-between; align-items: center;">
                        <div>
                            <div style="font-weight: 600; font-size: 1rem;">@(string.IsNullOrWhiteSpace(s.NomeCliente) ? "Cliente anonimo" : s.NomeCliente)</div>
                            <div style="font-size: 0.85rem; color: #6c757d; margin-top: 4px;">
                                @s.Consumazioni.Sum(c => c.Quantita) prodotti · € @totale.ToString("0.00")
                            </div>
                        </div>
                        <button class="btn-apri" @onclick='() => Nav.NavigateTo("/conto/" + s.Id)'
                                style="padding: 8px 20px; font-size: 0.9rem;">
                            Gestisci →
                        </button>
                    </div>
                }
                <hr style="margin: 20px 0;" />
            }

            <h3 style="margin-bottom: 12px;">@(sessioni.Any() ? "Apri altro conto" : "Ombrellone libero")</h3>
            <div class="apri-sessione">
                <input class="input-nome" placeholder="Nome cliente (opzionale)" @bind="nomeCliente" />
                <button class="btn-apri" @onclick="ApriSessione">
                    @(DateCtx.IsOggi ? "Apri sessione" : "Prenota")
                </button>
            </div>
        }
    }
</div>

@code {
    [Parameter] public int Id { get; set; }

    private List<BeachBar.Core.Entities.Sessione>? sessioni;
    private string? nomeCliente;
    private bool ombrelloneValido = true;
    private string? errore;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var ombrellone = await Sessioni.GetOmbrelloneByIdAsync(Id);
            if (ombrellone == null)
            {
                ombrelloneValido = false;
                errore = $"Ombrellone {Id} non trovato.";
                return;
            }
            sessioni = await Sessioni.GetSessioniAttivePerOmbrelloneAsync(Id, DateCtx.DataSelezionata);
        }
        catch (Exception ex)
        {
            ombrelloneValido = false;
            errore = $"Impossibile caricare i dati: {ex.Message}";
        }
    }

    private async Task ApriSessione()
    {
        errore = null;
        try
        {
            var nuova = await Sessioni.ApriSessioneAsync(Id, nomeCliente, DateCtx.DataSelezionata);
            Nav.NavigateTo("/conto/" + nuova.Id);
        }
        catch (Exception ex)
        {
            errore = $"Impossibile aprire la sessione: {ex.Message}";
        }
    }
}
