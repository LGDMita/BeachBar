@page "/storico"
@attribute [Authorize]
@using BeachBar.Core.Entities
@inject BeachBar.Infrastructure.Services.ISessioniService Sessioni
@inject BeachBar.Services.DateContext DateCtx
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="storico-container">
    <div class="header-storico">
        <h1 class="titolo-storico">Archivio Storico</h1>
    </div>

    <div class="date-navigator">
        <button class="btn-nav-data" @onclick="GiornoPrec">◀</button>
        <input type="date" class="input-data"
               value="@DateCtx.DataSelezionata.ToString("yyyy-MM-dd")"
               @onchange="OnDataChanged" />
        <button class="btn-nav-data" @onclick="GiornoSucc">▶</button>
        @if (!DateCtx.IsOggi)
        {
            <button class="btn-oggi" @onclick="TornaOggi">Oggi</button>
        }
    </div>

    <div class="storico-card">
        @if (errore != null)
        {
            <div class="alert-errore">⚠️ @errore</div>
        }
        else if (sessioni == null)
        {
            <div class="empty-state">Caricamento in corso...</div>
        }
        else if (!sessioni.Any())
        {
            <div class="empty-state">
                <div style="font-size: 3rem; margin-bottom: 1rem;">🏖️</div>
                <p>Nessuno scontrino per il @DateCtx.DataSelezionata.ToString("dd MMMM yyyy", ItCulture.IT).</p>
            </div>
        }
        else
        {
            <table class="tabella-storico">
                <thead>
                    <tr>
                        <th>Chiusura</th>
                        <th>Postazione</th>
                        <th>Cliente</th>
                        <th>Totale Incassato</th>
                        <th style="text-align: right;">Gestione</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in sessioni)
                    {
                        <tr>
                            <td>
                                <div class="date-stack">
                                    <span class="date-main">@s.Chiusura?.ToLocalTime().ToString("dd MMM yyyy")</span>
                                    <span class="date-sub">ore @s.Chiusura?.ToLocalTime().ToString("HH:mm")</span>
                                </div>
                            </td>
                            <td>
                                <div class="date-stack">
                                    @if (s.OmbrelloneId.HasValue)
                                    {
                                        <span class="badge-item">Ombrellone #@(s.Ombrellone?.Numero ?? s.OmbrelloneId)</span>
                                    }
                                    else
                                    {
                                        <span class="badge-item">Conto Extra</span>
                                    }
                                    <span class="date-sub">Sessione #@s.Id</span>
                                </div>
                            </td>
                            <td>
                                <span style="font-weight: 500;">@(string.IsNullOrEmpty(s.NomeCliente) ? "Occasionale" : s.NomeCliente)</span>
                            </td>
                            <td>
                                <span class="amount">€ @s.Consumazioni.Sum(c => c.Quantita * c.Prodotto.Prezzo).ToString("0.00")</span>
                            </td>
                            <td style="text-align: right;">
                                <button class="btn-action-delete" @onclick="() => Elimina(s.Id)">
                                    Elimina
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@code {
    private List<Sessione>? sessioni;
    private string? errore;

    protected override async Task OnInitializedAsync() => await CaricaDati();

    private async Task CaricaDati()
    {
        errore = null;
        sessioni = null;
        try
        {
            sessioni = await Sessioni.GetStoricoSessioniAsync(DateCtx.DataSelezionata);
        }
        catch (Exception ex)
        {
            errore = $"Impossibile caricare lo storico: {ex.Message}";
        }
    }

    private async Task OnDataChanged(ChangeEventArgs e)
    {
        if (DateOnly.TryParse(e.Value?.ToString(), out var data))
        {
            DateCtx.Imposta(data);
            await CaricaDati();
        }
    }

    private async Task GiornoPrec() { DateCtx.Arretra(); await CaricaDati(); }
    private async Task GiornoSucc() { DateCtx.Avanza(); await CaricaDati(); }
    private async Task TornaOggi() { DateCtx.TornaOggi(); await CaricaDati(); }

    private async Task Elimina(int id)
    {
        bool confermato = await JS.InvokeAsync<bool>("confirm", "Eliminare definitivamente questo scontrino?");
        if (confermato)
        {
            errore = null;
            try
            {
                await Sessioni.EliminaSessioneStoricoAsync(id);
                await CaricaDati();
            }
            catch (Exception ex)
            {
                errore = $"Impossibile eliminare lo scontrino: {ex.Message}";
            }
        }
    }
}
