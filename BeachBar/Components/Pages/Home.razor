@page "/"
@attribute [Authorize]
@inject BeachBar.Infrastructure.Services.ISessioniService Sessioni
@inject BeachBar.Infrastructure.Services.IImpostazioniService Impostazioni
@inject BeachBar.Services.DateContext DateCtx
@inject NavigationManager Nav

<div class="dashboard">

    <div class="date-navigator">
        <button class="btn-nav-data" @onclick="GiornoPrec">◀</button>
        <input type="date" class="input-data"
               value="@DateCtx.DataSelezionata.ToString("yyyy-MM-dd")"
               @onchange="OnDataChanged" />
        <button class="btn-nav-data" @onclick="GiornoSucc">▶</button>
        @if (!DateCtx.IsOggi)
        {
            <button class="btn-oggi" @onclick="TornaOggi">Oggi</button>
        }
    </div>

    <div class="statistiche">
        <div class="stat-card">
            <span class="stat-valore">@ombrelloniAttivi</span>
            <span class="stat-label">Ombrelloni attivi</span>
        </div>
        <div class="stat-card">
            <span class="stat-valore">€ @aperto.ToString("0.00")</span>
            <span class="stat-label">Totale aperto</span>
        </div>
        <div class="stat-card">
            <span class="stat-valore">€ @incassato.ToString("0.00")</span>
            <span class="stat-label">@(DateCtx.IsOggi ? "Incassato oggi" : "Incassato")</span>
        </div>
    </div>

    @if (errore != null)
    {
        <div class="alert-errore">⚠️ @errore</div>
    }
    else if (ombrelloni == null)
    {
        <p class="caricamento">Caricamento...</p>
    }
    else if (!ombrelloni.Any())
    {
        <div class="empty-state">
            <div class="empty-state-icon">🏖️</div>
            <p class="empty-state-testo">Nessun ombrellone configurato.</p>
            <a href="/impostazioni" class="empty-state-link">Vai alle Impostazioni →</a>
        </div>
    }
    else if (usaGrigliaRighe)
    {
        @* Layout per righe: usato sia con posizioni custom sia solo con bordi configurati *@
        <div class="griglia-wrapper">
            <div class="griglia-custom">
                @for (int r = 0; r < numRighe; r++)
                {
                    <div class="griglia-riga-custom">
                        @for (int c = 0; c < numColonne; c++)
                        {
                            int idx = r * numColonne + c;
                            var omb = idx < celleGrid.Length ? celleGrid[idx] : null;

                            @if (omb != null)
                            {
                                <button class="ombrellone @(omb.Occupato ? "occupato" : "libero")"
                                        @onclick="() => Vai(omb)">
                                    <span class="numero">@omb.Numero</span>
                                    @if (omb.Occupato)
                                    {
                                        @if (omb.Sessioni.Count == 1)
                                        {
                                            var nome = omb.Sessioni.First().NomeCliente;
                                            <span class="stato">Occupato</span>
                                            @if (!string.IsNullOrWhiteSpace(nome))
                                            {
                                                <span class="omb-nome">@nome</span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="stato">@omb.Sessioni.Count conti</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="stato">Libero</span>
                                    }
                                </button>
                            }
                            else
                            {
                                <div class="ombrellone-placeholder"></div>
                            }

                            @if (c < numColonne - 1)
                            {
                                bool vOn = bordiV.Contains(c);
                                <div class="griglia-sep-v @(vOn ? "sep-attivo" : "")"></div>
                            }
                        }
                    </div>

                    @if (r < numRighe - 1)
                    {
                        bool hOn = bordiH.Contains(r);
                        <div class="griglia-sep-h-row @(hOn ? "sep-attivo" : "")">
                            @for (int c = 0; c < numColonne; c++)
                            {
                                <div class="griglia-sep-h-seg"></div>
                                @if (c < numColonne - 1)
                                {
                                    <div class="griglia-sep-corner"></div>
                                }
                            }
                        </div>
                    }
                }
            </div>
        </div>
    }
    else
    {
        @* Layout sequenziale classico (nessun bordo, nessuna posizione custom) *@
        <div class="griglia-wrapper">
            <div class="griglia" style="grid-template-columns: repeat(@colonne, 120px);">
                @foreach (var o in ombrelloni)
                {
                    <button class="ombrellone @(o.Occupato ? "occupato" : "libero")"
                            @onclick="() => Vai(o)">
                        <span class="numero">@o.Numero</span>
                        @if (o.Occupato)
                        {
                            @if (o.Sessioni.Count == 1)
                            {
                                var nome = o.Sessioni.First().NomeCliente;
                                <span class="stato">Occupato</span>
                                @if (!string.IsNullOrWhiteSpace(nome))
                                {
                                    <span class="omb-nome">@nome</span>
                                }
                            }
                            else
                            {
                                <span class="stato">@o.Sessioni.Count conti</span>
                            }
                        }
                        else
                        {
                            <span class="stato">Libero</span>
                        }
                    </button>
                }
            </div>
        </div>
    }

    @if (ombrelloniNonInGriglia.Count > 0)
    {
        <div class="avviso-griglia-parziale">
            <span>
                @ombrelloniNonInGriglia.Count
                @(ombrelloniNonInGriglia.Count == 1 ? "ombrellone non visibile" : "ombrelloni non visibili")
                nella griglia
                (@string.Join(", ", ombrelloniNonInGriglia.Take(5).Select(o => "#" + o.Numero))@(ombrelloniNonInGriglia.Count > 5 ? "..." : ""))
            </span>
            <a href="/impostazioni">Posiziona nella mappa →</a>
        </div>
    }

    <div class="conti-extra-section">
        <div class="conti-extra-header">
            <div>
                <h3 class="conti-extra-titolo">Conti volanti</h3>
                <span class="conti-extra-subtitle">Clienti senza postazione fissa</span>
            </div>
            @if (!mostraNuovoContoExtra)
            {
                <button class="btn-nuovo-conto" @onclick="() => mostraNuovoContoExtra = true">
                    + Nuovo
                </button>
            }
        </div>

        @if (mostraNuovoContoExtra)
        {
            var ombrelloniSelectList = usaLayoutCustom
                ? (ombrelloni ?? new()).Where(o => o.CellaIndice.HasValue).OrderBy(o => o.Numero).ToList()
                : (ombrelloni ?? new());

            <div class="nuovoconto-form">
                <input class="input-nome nuovoconto-input" placeholder="Nome cliente (opzionale)" @bind="nomeContoExtra" />
                <select class="nuovoconto-select" @bind="ombrelloneExtraStr">
                    <option value="">Nessun ombrellone</option>
                    @foreach (var o in ombrelloniSelectList)
                    {
                        <option value="@o.Id">Ombrellone @o.Numero</option>
                    }
                </select>
                <div class="nuovoconto-azioni">
                    <button class="btn-apri" @onclick="ApriContoExtra">
                        @(DateCtx.IsOggi ? "Apri" : "Prenota")
                    </button>
                    <button class="btn-annulla-form" @onclick="() => { mostraNuovoContoExtra = false; nomeContoExtra = null; ombrelloneExtraStr = null; }">
                        ✕
                    </button>
                </div>
            </div>
        }

        @if (contiExtra != null && contiExtra.Any())
        {
            <div class="conti-extra-griglia">
                @foreach (var c in contiExtra)
                {
                    var totale = c.Consumazioni.Sum(x => x.Quantita * x.Prodotto.Prezzo);
                    <div class="conto-extra-card">
                        <div class="conto-extra-info">
                            <div class="conto-extra-nome">@(string.IsNullOrWhiteSpace(c.NomeCliente) ? "Ospite" : c.NomeCliente)</div>
                            <div class="conto-extra-meta">
                                @c.Consumazioni.Sum(x => x.Quantita) prodotti &middot; € @totale.ToString("0.00")
                            </div>
                        </div>
                        <button class="btn-apri conto-extra-btn" @onclick='() => Nav.NavigateTo("/conto/" + c.Id)'>
                            →
                        </button>
                    </div>
                }
            </div>
        }
        else if (contiExtra != null && !contiExtra.Any() && !mostraNuovoContoExtra)
        {
            <p class="conti-extra-vuoto">Nessun conto volante aperto.</p>
        }
    </div>
</div>

@code {
    private List<BeachBar.Core.Entities.Ombrellone>? ombrelloni;
    private List<BeachBar.Core.Entities.Sessione>? contiExtra;
    private decimal aperto;
    private decimal incassato;
    private int ombrelloniAttivi;
    private int colonne = 4;
    private int numRighe = 5;
    private int numColonne = 4;
    private bool usaLayoutCustom;
    private bool usaGrigliaRighe;
    private BeachBar.Core.Entities.Ombrellone?[] celleGrid = Array.Empty<BeachBar.Core.Entities.Ombrellone?>();
    private HashSet<int> bordiV = new();
    private HashSet<int> bordiH = new();
    private string? errore;
    private bool mostraNuovoContoExtra;
    private string? nomeContoExtra;
    private string? ombrelloneExtraStr;

    private List<BeachBar.Core.Entities.Ombrellone> ombrelloniNonInGriglia = new();

    private static HashSet<int> ParseBordi(string? s) =>
        s == null
            ? new()
            : s.Split(',', StringSplitOptions.RemoveEmptyEntries)
               .Where(x => int.TryParse(x, out _))
               .Select(int.Parse)
               .ToHashSet();

    protected override async Task OnInitializedAsync() => await CaricaDati();

    private async Task CaricaDati()
    {
        errore = null;
        ombrelloni = null;
        contiExtra = null;
        try
        {
            ombrelloni = await Sessioni.GetOmbrelloniAsync(DateCtx.DataSelezionata);
            contiExtra = await Sessioni.GetContiExtraAsync(DateCtx.DataSelezionata);
            var stats = await Impostazioni.GetStatisticheAsync(DateCtx.DataSelezionata);
            aperto = stats.aperto;
            incassato = stats.incassato;
            ombrelloniAttivi = stats.ombrelloniAttivi;
            var imp = await Impostazioni.GetImpostazioniAsync();
            colonne = imp.NumeroColonne;
            numColonne = imp.NumeroColonne;
            numRighe = imp.NumeroRighe;
            bordiV = ParseBordi(imp.BordiVerticali);
            bordiH = ParseBordi(imp.BordiOrizzontali);

            usaLayoutCustom = ombrelloni.Any(o => o.CellaIndice.HasValue);
            bool hasBordi = bordiV.Count > 0 || bordiH.Count > 0;
            usaGrigliaRighe = usaLayoutCustom || hasBordi;

            if (usaLayoutCustom)
            {
                // Posizionamento esplicito: usa CellaIndice per costruire la griglia
                celleGrid = new BeachBar.Core.Entities.Ombrellone?[numRighe * numColonne];
                foreach (var o in ombrelloni.Where(o => o.CellaIndice.HasValue))
                {
                    int ci = o.CellaIndice!.Value;
                    if (ci < celleGrid.Length) celleGrid[ci] = o;
                }
                ombrelloniNonInGriglia = ombrelloni.Where(o => !o.CellaIndice.HasValue).ToList();
            }
            else
            {
                ombrelloniNonInGriglia = new();
            }

            if (!usaLayoutCustom && hasBordi)
            {
                // Nessuna posizione custom, ma ci sono bordi: rendering per righe con layout sequenziale
                int righeCalcolate = numColonne > 0
                    ? (ombrelloni.Count + numColonne - 1) / numColonne
                    : 1;
                numRighe = righeCalcolate;
                celleGrid = new BeachBar.Core.Entities.Ombrellone?[numRighe * numColonne];
                for (int i = 0; i < ombrelloni.Count && i < celleGrid.Length; i++)
                    celleGrid[i] = ombrelloni[i];
            }
        }
        catch (Exception ex)
        {
            errore = $"Impossibile caricare la dashboard: {ex.Message}";
        }
    }

    private async Task OnDataChanged(ChangeEventArgs e)
    {
        if (DateOnly.TryParse(e.Value?.ToString(), out var data))
        {
            DateCtx.Imposta(data);
            await CaricaDati();
        }
    }

    private async Task GiornoPrec() { DateCtx.Arretra(); await CaricaDati(); }
    private async Task GiornoSucc() { DateCtx.Avanza(); await CaricaDati(); }
    private async Task TornaOggi() { DateCtx.TornaOggi(); await CaricaDati(); }

    private void Vai(BeachBar.Core.Entities.Ombrellone o)
    {
        if (o.Sessioni.Count == 1)
            Nav.NavigateTo("/conto/" + o.Sessioni.First().Id);
        else
            Nav.NavigateTo("/ombrellone/" + o.Id);
    }

    private async Task ApriContoExtra()
    {
        errore = null;
        try
        {
            BeachBar.Core.Entities.Sessione nuova;
            if (int.TryParse(ombrelloneExtraStr, out var ombrId))
                nuova = await Sessioni.ApriSessioneAsync(ombrId, nomeContoExtra, DateCtx.DataSelezionata);
            else
                nuova = await Sessioni.ApriContoExtraAsync(nomeContoExtra, DateCtx.DataSelezionata);
            Nav.NavigateTo("/conto/" + nuova.Id);
        }
        catch (Exception ex)
        {
            errore = $"Impossibile aprire il conto: {ex.Message}";
        }
    }
}
